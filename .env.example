# Warehouse Scan — copy to Warehouse_scan/.env

WAREHOUSE_URL=http://127.0.0.1:8000
SCAN_API_KEY=scan-dev-key
SCAN_SECRET_KEY=change-me-scan-secret
SCAN_BACKEND_URL=http://127.0.0.1:5003
SCAN_API_HOST=127.0.0.1
SCAN_API_PORT=5003
SCAN_PORT=5002
SCAN_HOST=0.0.0.0
# Set to true when serving over HTTPS so the login cookie is sent only over TLS.
# Leave false for plain-HTTP LAN deployments (the cookie would not be sent otherwise).
SCAN_COOKIE_SECURE=false
FLASK_ENV=development
# SCAN_DATABASE=
# SCAN_INSTANCE_PATH=
